<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Dipayan Dey | FinTech Developer & AI Systems Portfolio</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    
    <!-- FontAwesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* ==========================================================================
           DESIGN SYSTEM & VARIABLES (Databricks + Anthropic Blended Theme)
           ========================================================================== */
        :root {
            --bg-primary: #06070a;
            --bg-card: rgba(13, 17, 27, 0.65);
            --bg-card-hover: rgba(20, 26, 40, 0.85);
            --border-color: rgba(255, 255, 255, 0.06);
            
            --text-primary: #f4f0ea;
            --text-secondary: #b0a89f;
            --text-muted: #7c756c;
            
            --color-info: #85b7eb;
            --color-info-glow: rgba(133, 183, 235, 0.15);
            --color-accent: #ff5630; /* Databricks Coral */
            --color-accent-glow: rgba(255, 86, 48, 0.18);
            --color-success: #10b981;
            --color-success-glow: rgba(16, 185, 129, 0.15);
            --color-warning: #f59e0b;
            --color-warning-glow: rgba(245, 158, 11, 0.15);
            --color-crawler: #d946ef;
            --color-crawler-glow: rgba(217, 70, 239, 0.15);
            
            --font-sans: 'Outfit', -apple-system, sans-serif;
            --font-serif: 'Lora', Georgia, serif;
            --font-mono: 'JetBrains Mono', monospace;
            --transition: all 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        /* ==========================================================================
           GLOBAL BASE STYLES
           ========================================================================== */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-sans);
            background-color: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            align-items: center;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            position: relative;
        }

        /* Ambient Glowing Blobs */
        body::before {
            content: '';
            position: fixed;
            top: -20%;
            left: -15%;
            width: 700px;
            height: 700px;
            background: radial-gradient(circle, rgba(255, 86, 48, 0.08) 0%, rgba(255, 86, 48, 0) 70%);
            z-index: -1;
            pointer-events: none;
            filter: blur(100px);
        }

        body::after {
            content: '';
            position: fixed;
            bottom: -20%;
            right: -15%;
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(99, 102, 241, 0.07) 0%, rgba(99, 102, 241, 0) 70%);
            z-index: -1;
            pointer-events: none;
            filter: blur(100px);
        }

        /* ==========================================================================
           HERO HEADER SECTION
           ========================================================================== */
        header {
            text-align: center;
            padding: 100px 20px 40px;
            max-width: 800px;
            z-index: 10;
        }

        .profile-photo-container {
            margin-bottom: 24px;
            position: relative;
            display: inline-block;
        }

        .profile-photo {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            border: 3px solid var(--border-color);
            object-fit: cover;
            box-shadow: 0 0 30px rgba(255, 86, 48, 0.15);
            transition: var(--transition);
        }

        .profile-photo-container::after {
            content: '';
            position: absolute;
            top: -5px;
            left: -5px;
            right: -5px;
            bottom: -5px;
            border-radius: 50%;
            border: 1px dashed rgba(255, 86, 48, 0.25);
            animation: rotate 60s linear infinite;
        }

        @keyframes rotate {
            100% { transform: rotate(360deg); }
        }

        .profile-photo:hover {
            transform: scale(1.04);
            border-color: var(--color-accent);
            box-shadow: 0 0 35px rgba(255, 86, 48, 0.35);
        }

        .profile-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background-color: var(--color-accent-glow);
            border: 1px solid rgba(255, 86, 48, 0.3);
            color: #ffaa95;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 24px;
            letter-spacing: 0.8px;
            text-transform: uppercase;
        }

        h1 {
            font-family: var(--font-serif);
            font-size: 3.8rem;
            font-weight: 700;
            letter-spacing: -1px;
            line-height: 1.1;
            background: linear-gradient(135deg, #ffffff 40%, #ffd0c5 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 18px;
        }

        .subtitle {
            font-size: 1.2rem;
            color: var(--text-secondary);
            font-weight: 400;
            max-width: 620px;
            margin: 0 auto 30px auto;
            line-height: 1.6;
        }

        /* Social links bar */
        .social-links {
            display: flex;
            justify-content: center;
            gap: 16px;
            margin-bottom: 20px;
        }

        .social-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background-color: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            font-size: 18px;
            text-decoration: none;
            transition: var(--transition);
        }

        .social-btn:hover {
            color: var(--text-primary);
            background-color: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.2);
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.4);
        }

        /* ==========================================================================
           PROJECTS GRID SECTION
           ========================================================================== */
        .projects-section {
            width: 100%;
            max-width: 1200px;
            padding: 40px 24px;
            z-index: 10;
        }

        .projects-section h2 {
            font-family: var(--font-serif);
        }

        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 24px;
        }

        .card {
            background: var(--bg-card);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 30px;
            text-decoration: none;
            color: inherit;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: var(--transition);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.4);
            position: relative;
            overflow: hidden;
            min-height: 230px;
        }

        /* Category accent hovers */
        .card:hover {
            transform: translateY(-6px);
            border-color: rgba(255, 86, 48, 0.25);
            background: var(--bg-card-hover);
        }

        .card-ghibli:hover { box-shadow: 0 12px 35px rgba(133, 183, 235, 0.12); }
        .card-risk:hover { box-shadow: 0 12px 35px rgba(255, 86, 48, 0.15); }
        .card-finance:hover { box-shadow: 0 12px 35px rgba(99, 102, 241, 0.12); }
        .card-markdown:hover { box-shadow: 0 12px 35px rgba(245, 158, 11, 0.12); }
        .card-crawler:hover { box-shadow: 0 12px 35px rgba(217, 70, 239, 0.16); }

        /* Icon headers */
        .card-icon {
            font-size: 28px;
            margin-bottom: 20px;
            display: inline-block;
        }

        .card-ghibli .card-icon { color: var(--color-info); }
        .card-risk .card-icon { color: var(--color-accent); }
        .card-finance .card-icon { color: var(--color-success); }
        .card-markdown .card-icon { color: var(--color-warning); }
        .card-crawler .card-icon { color: var(--color-crawler); }

        .card-content h3 {
            font-family: var(--font-serif);
            font-size: 19px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
            letter-spacing: -0.2px;
        }

        .card-content p {
            font-size: 13.5px;
            color: var(--text-secondary);
            line-height: 1.55;
            margin-bottom: 24px;
        }

        .card-footer {
            font-size: 11.5px;
            font-weight: 600;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 6px;
            transition: gap 0.2s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .card:hover .card-footer {
            gap: 10px;
        }

        .card-ghibli .card-footer { color: var(--color-info); }
        .card-risk .card-footer { color: var(--color-accent); }
        .card-finance .card-footer { color: var(--color-success); }
        .card-markdown .card-footer { color: var(--color-warning); }
        .card-crawler .card-footer { color: var(--color-crawler); }

        /* Featured project badge */
        .featured-badge {
            position: absolute;
            top: 16px;
            right: 16px;
            background-color: var(--color-accent-glow);
            border: 1px solid rgba(255, 86, 48, 0.3);
            color: #ffd0c5;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.8px;
            text-transform: uppercase;
        }

        /* ==========================================================================
           FOOTER SECTION
           ========================================================================== */
        footer {
            text-align: center;
            padding: 60px 20px 40px;
            font-size: 13px;
            color: var(--text-muted);
            width: 100%;
            border-top: 1px solid rgba(255, 255, 255, 0.03);
            background-color: rgba(0, 0, 0, 0.2);
            z-index: 10;
        }

        footer strong {
            color: var(--text-primary);
            font-weight: 600;
        }

        /* ==========================================================================
           RESPONSIVE MOBILE STYLES
           ========================================================================== */
        @media (max-width: 768px) {
            header {
                padding: 60px 20px 20px;
            }
            h1 {
                font-size: 2.8rem;
            }
            .subtitle {
                font-size: 1.1rem;
            }
            .projects-section {
                padding: 20px 16px;
            }
        }
    </style>
</head>
<body>

    <!-- ANIMATED MESH BACKDROP -->
